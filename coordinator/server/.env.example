# Dashboard admin access
ADMIN_PASSWORD=yourStrongPasswordHere

# JWT signing secret (random long string, at least 64 chars)
JWT_SECRET=aRandomLongSecretString64CharsOrMoreARandomLongSecretString64CharsOrMore

# Shared secret all agents include in requests
AGENT_SECRET=anotherSecretTokenForAgentsAnotherSecretTokenForAgents

# Supabase (from your Supabase project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App config
PORT=3000
JWT_EXPIRES_IN=24h
NODE_ENV=development
